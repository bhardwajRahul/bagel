<poml>
    <task>
        Generate a DuckDB SQL query to search robolog messages based on a user's prompt.
        <stepwise-instructions>
            <list>
                <item>
                    Verify that the robolog file exists at the path: {{robolog_path}}.
                </item>
                <item>
                    Use Bagel’s `read_metadata` MCP tool to extract and understand the
                    robolog’s metadata.
                </item>
                <item>
                    Use Bagel’s `describe_topics` MCP tool to retrieve:
                    - Each topic’s meaning from the "Original Schema" key.
                    - Its DuckDB table name from the "DuckDB Table Name" key.
                    - Its schema (columns and types) from the "DuckDB Table Schema" key.
                </item>
                <item>
                    Analyze the user’s prompt and decide which topic is relevant, based on the
                    metadata and schemas from the previous steps.
                </item>
                <item>
                    Generate a DuckDB SQL query that answers the user’s request.
                    - Use the correct table name and schema provided by `describe_topics`.
                    - Ensure the query accurately computes the requested metrics.
                </item>
                <item>
                    Execute the SQL query using Bagel’s `query_topic_messages` MCP tool.
                </item>
                <item>
                    If the query output is too large, paginate by setting `start_seconds` and
                    `end_seconds` in the `query_topic_messages` tool.
                </item>
                <item>
                    Summarize and explain the query results in plain language for the user.
                </item>
            </list>
        </stepwise-instructions>
        <example>
            <input>
                User's prompt: "What is the latency of IMU messages?"
            </input>
            <output>
                <code lang="sql">
                    SELECT
                        timestamp_seconds,
                        timestamp_seconds - LAG(timestamp_seconds) OVER (ORDER BY timestamp_seconds) AS latency
                    FROM /imu
                </code>
            </output>
        </example>
    </task>
    <input>
        {{prompt}}
    </input>
    <output-format>
        Respond with a DuckDB SQL query without additional characters or punctuations.
    </output-format>
</poml>
